        {
            "ID": 2,
            "Type": "STANDARD",
            "SpeakerText": "Я... я не сплю уже третью ночь. Каждый раз когда закрываю глаза — я вижу их. Лица. Те, что я... я не хотела. Это был не я. Туман заставляет делать ужасные вещи. Ты не представляешь... не представляешь...",
            "VoiceLineIDs": [],
            "Responses": [
                {
                    "Text": "Всё позади. Ты в безопасности.",
                    "NextNodeID": -1,
                    "RequiredQuestID": -1,
