        {
            "ID": 1,
            "Type": "STANDARD",
            "SpeakerText": "Заходи, не стесняйся. Жалобы есть? Или просто так заглянул?",
            "VoiceLineIDs": [],
            "Responses": [
                {
                    "Text": "Как дела в лазарете?",
                    "NextNodeID": 2,
                    "RequiredQuestID": -1,
                    "ActionType": "NONE"
                },
                {
                    "Text": "Что можете рассказать про этот вирус?",
