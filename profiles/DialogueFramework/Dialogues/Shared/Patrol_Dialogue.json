                    "ActionType": "SHOW_QUEST_LIST"
                },
                {
                    "Text": "Как обстановка?",
                    "NextNodeID": 2,
                    "RequiredQuestID": -1,
                    "ActionType": "NONE"
                },
                {
                    "Text": "Я принёс, что просили.",
                    "NextNodeID": 5,
                    "RequiredQuestID": 1002,
                    "ActionType": "NONE"
                },
                {
                    "Text": "Бывай.",
                    "NextNodeID": -1,
